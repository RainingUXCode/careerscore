{
  "name": "careerscore",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n backend,web -c magenta,cyan \"npm:dev:backend\" \"npm:dev:web\"",
    "dev:backend": "cd ../backend && .venv\\Scripts\\python.exe manage.py runserver 127.0.0.1:8000",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "preview": "vite preview"
  },
  "dependencies": {
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
