# Copie este arquivo para .env (ou configure a variável equivalente no painel
# da hospedagem escolhida) e preencha com sua própria chave. NUNCA coloque o
# valor real aqui neste arquivo de exemplo, e NUNCA use prefixos como VITE_,
# NEXT_PUBLIC_ ou PUBLIC_ — eles fariam a chave ir parar no bundle do navegador.

# Chave da JSearch (obtida em openwebninja.com — API oficial da OpenWeb Ninja,
# autenticação via header X-API-Key).
# Usada apenas pelo servidor backend — nunca é enviada ao cliente.
JSEARCH_API_KEY=SUA_CHAVE_AQUI

# Chave da Gemini API. Deve existir apenas no servidor/backend.
# Nunca use VITE_GEMINI_API_KEY, NEXT_PUBLIC_GEMINI_API_KEY ou PUBLIC_GEMINI_API_KEY.
GEMINI_API_KEY=SUA_CHAVE_AQUI

# Opcional. Use um modelo estável/permitido no seu projeto.
GEMINI_MODEL=gemini-3.5-flash

# Django. Gere um valor forte e exclusivo no ambiente de produção.
DJANGO_SECRET_KEY=ALTERE_EM_PRODUCAO
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
API_ANON_RATE=60/hour
RESUME_ANALYSIS_RATE=10/hour
